# Groq API Key for Llama 3 model access
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Groq Model Identifier (defaults to llama-3.1-8b-instant if not set)
GROQ_MODEL=llama-3.1-8b-instant

# CORS Allowed Origin (e.g. your Vercel frontend URL, defaults to * if not set)
ALLOWED_ORIGIN=*

# Supabase Auth and Database connection variables
# Get these from your Supabase Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
# WARNING: NEVER expose this service role key to the frontend. Keep it backend-only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

