# Groq API Key for Llama 3 model access
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Groq Model Identifier (defaults to llama-3.1-8b-instant if not set)
GROQ_MODEL=llama-3.1-8b-instant

# CORS Allowed Origin (e.g. your Vercel frontend URL, defaults to * if not set)
ALLOWED_ORIGIN=*
